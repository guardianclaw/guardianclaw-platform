# claw Platform - Web Environment Variables
# Copy this file to .env.local and fill in the values
#
# Reference: SECURITY_SPEC.md Section 9.1

# =============================================================================
# API Configuration
# =============================================================================

# Main API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8787

# Chamber API endpoint (for security testing demos)

# =============================================================================
# Solana Configuration
# =============================================================================

# Solana RPC endpoint
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Solana network (mainnet-beta, devnet, testnet)
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# =============================================================================
# Security Configuration
# =============================================================================

# HMAC secret for Memory Shield demo (Chamber)
# Generate with: openssl rand -hex 32
# IMPORTANT: Use different values for development and production
NEXT_PUBLIC_DEMO_HMAC_SECRET=your-hmac-secret-here-generate-with-openssl-rand-hex-32

# =============================================================================
# Optional: Analytics
# =============================================================================

# PostHog analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
