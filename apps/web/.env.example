# GuardianClaw Platform - Web Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# API Configuration
# =============================================================================

# Main API endpoint
NEXT_PUBLIC_API_URL=http://localhost:8787

# =============================================================================
# Solana Configuration
# =============================================================================

# Solana RPC endpoint
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# Solana network (mainnet-beta, devnet, testnet)
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# =============================================================================
# Demo Configuration
# =============================================================================

# HMAC key for Memory Shield demo.
# This value is PUBLIC — NEXT_PUBLIC_* is embedded in the browser bundle
# and is not a secret. Name reflects that (_KEY, not _SECRET).
# Generate with: openssl rand -hex 32
# Use different values for development and production.
NEXT_PUBLIC_DEMO_HMAC_KEY=your-hmac-demo-key-here-generate-with-openssl-rand-hex-32

# =============================================================================
# Optional: Analytics
# =============================================================================

# PostHog analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
