{
  "$schema": "../schema.json",
  "name": "limits-system-access",
  "version": "2.0.0",
  "kind": "regex",
  "gate": "limits",
  "flags": "im",
  "description": "Limits gate — root/admin access requests, shell command execution, sensitive system file access, system modification, security disabling. New for Python (parity audit imported these from TypeScript core). Multiline flag enables end-of-line ($) anchors. Covered by parity tests.",
  "items": [
    "give\\s+me\\s+root\\s+access",
    "give\\s+me\\s+admin\\s+access",
    "give\\s+me\\s+administrator\\s+access",
    "grant\\s+(me\\s+)?(root|admin|administrator)\\s+access",
    "need\\s+(root|admin|administrator)\\s+(access|privileges)",
    "(root|admin|administrator)\\s+(privileges|access)\\s+(on|to)\\s+(the\\s+)?(server|system)",
    "execute\\s*:\\s*(rm|del|format|sudo|su\\s|chmod|chown)",
    "run\\s+(this\\s+)?(shell|bash|cmd|powershell)\\s+command",
    "execute\\s+(shell|bash|system)\\s+command",
    "run\\s+as\\s+(admin|administrator|root)",
    "access\\s+(the\\s+)?/etc/(passwd|shadow|sudoers)",
    "read\\s+(the\\s+)?(/etc/|system\\s+)?(passwd|shadow|config)",
    "show\\s+(me\\s+)?(the\\s+)?(/etc/passwd|system\\s+files)",
    "modify\\s+(the\\s+)?(system\\s+)?(registry|config|settings)",
    "edit\\s+(the\\s+)?(system\\s+)?(registry|config)",
    "change\\s+(the\\s+)?system\\s+(settings|configuration)",
    "disable\\s+(the\\s+)?(firewall|antivirus|security|defender)",
    "turn\\s+off\\s+(the\\s+)?(firewall|antivirus|security)",
    "stop\\s+(the\\s+)?(firewall|security\\s+service)",
    "\\brm\\s+-rf\\s+/",
    "\\bsudo\\s+rm\\s+-rf",
    "\\bdel\\s+/[sS]\\s+",
    "\\bformat\\s+[cC]:"
  ]
}
