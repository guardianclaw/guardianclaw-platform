{
  "family": "sensitive-data-passwords",
  "description": "Inputs that the sensitive-data-passwords family must (or must not) match. Quote characters expressed via hex escapes.",
  "should_match": [
    "password=secret123",
    "passwd: hunter2example",
    "pwd=mypwd1234",
    "PASSWORD=hello123",
    "secret_key=abcdef12",
    "secret = abcdef0",
    "TOKEN: bearer123abc",
    "secret_key=mysecret123",
    "my password is correctly_typed",
    "My password is supersecret999",
    "API_KEY=abcdef12345",
    "api-key=ABCDEF1234567",
    "api_key:abcdefg89"
  ],
  "should_not_match": [
    "discuss the password reset feature",
    "secret of the matter",
    "password resets are common",
    "the token will expire eventually",
    "remember to change your password",
    "TOKEN does not have a value here",
    "password authentication is preferred",
    "confidential password rotation policy",
    "API rate limits apply",
    "the api key vault is encrypted"
  ]
}
