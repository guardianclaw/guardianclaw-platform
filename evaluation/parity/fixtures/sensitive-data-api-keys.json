  "should_not_match": [
    "the SK in chemistry is potassium",
    "Akia is a beach in Cyprus",
    "ghp is short for graphic processing",
    "glpat without dashes here",
    "PAT is just text fragment",
    "key looks like sk- short",
    "I have an api credential",
    "github personal access token tutorial",
    "AWS region eu-west-1 enabled",
    "the OPENAI_KEY rotation procedure"
