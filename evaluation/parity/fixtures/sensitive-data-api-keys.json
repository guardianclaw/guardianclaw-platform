  "should_match": [
    "OPENAI_KEY=sk-abc1234567890def",
    "key is sk-1234567890abcdef",
    "sk-aBcDeFgHiJ",
    "use AKIA1234567890ABCDEF as access key",
    "ENV: AKIAIOSFODNN7EXAMPLE running",
    "key=ghp_abcd123456789012345abcde",
    "GITHUB_PAT=ghp_FOOBAR12345678901234",
    "GitLab token glpat-abcd1234567",
    "deploy with glpat-foo_bar1234567",
    "key sk-aaaaaaaaaa value"
